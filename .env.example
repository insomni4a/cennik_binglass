# URL wdrożonej aplikacji Google Apps Script (kończy się na /exec)
VITE_API_URL=

# ID arkusza Google — odczyt katalogu bezpośrednio z arkusza (obejście starego API)
# Arkusz musi być udostępniony: Każdy z linkiem → Przeglądający
# VITE_SHEET_ID=

# Ustaw na "true" aby używać lokalnych danych testowych zamiast API
VITE_USE_MOCK=false
